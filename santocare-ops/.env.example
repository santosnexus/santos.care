# ─── Core (required) ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/santos_care?schema=public"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Auth (required) ──────────────────────────────────────────────────────────
OPS_AUTH_USER="admin"
OPS_AUTH_PASS="change-this-in-production"

# ─── Email: Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Santos Care <no-reply@santos.care>"

# ─── Payments: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ─── Messaging: Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"  # Twilio sandbox or your WhatsApp Business number
TWILIO_SMS_FROM="+1..."

# ─── Background Jobs: Inngest ─────────────────────────────────────────────────
INNGEST_EVENT_KEY="..."
INNGEST_SIGNING_KEY="signkey-prod-..."

# ─── Error Tracking: Sentry ───────────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."

# ─── Storage: Supabase ────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Rate Limiting: Upstash Redis ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ─── Exchange Rates ───────────────────────────────────────────────────────────
OPEN_EXCHANGE_RATES_APP_ID="..."

# ─── Compliance ───────────────────────────────────────────────────────────────
# 256-bit key in hex (generate with: openssl rand -hex 32)
FIELD_ENCRYPTION_KEY="..."
DATA_RETENTION_YEARS="7"
